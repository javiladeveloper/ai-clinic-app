# Fastlane — despliegue automático de Sania (Android + iOS).
# Cada plataforma tiene sus lanes. Los secretos NUNCA van aquí: se inyectan por
# variables de entorno desde GitHub Actions (ver .github/workflows/).

# ─────────────────────────── ANDROID ───────────────────────────
platform :android do
  # OJO: sube al canal de PRUEBAS CERRADAS (Closed testing), cuyo track en la API de
  # Google se llama "alpha" (el nombre por defecto del canal cerrado). NO es "internal"
  # (Prueba interna) — ese es otro canal distinto y era donde llegaban antes los AAB
  # sin que aparecieran en Pruebas cerradas. La lane se sigue llamando :internal solo
  # porque el workflow la invoca así (fastlane android internal); lo que manda es el track.
  desc "Sube el AAB (ya compilado por Gradle) a Play Store, canal 'alpha' (Pruebas cerradas)"
  lane :internal do
    upload_to_play_store(
      package_name: "pe.saniape.app",
      track: "alpha",                          # alpha = canal de PRUEBAS CERRADAS
      aab: "composeApp/build/outputs/bundle/release/composeApp-release.aab",
      # La cuenta de servicio de Google Play (JSON) llega por env var como archivo temporal.
      json_key: ENV["PLAY_STORE_JSON_KEY_PATH"],
      release_status: "completed",             # publica directo a los testers cerrados (estamos en pruebas cerradas)
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Sube a producción (revisar antes de usar)"
  lane :production do
    upload_to_play_store(
      package_name: "pe.saniape.app",
      track: "production",
      aab: "composeApp/build/outputs/bundle/release/composeApp-release.aab",
      json_key: ENV["PLAY_STORE_JSON_KEY_PATH"],
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end

# ─────────────────────────── iOS ───────────────────────────
platform :ios do
  desc "Compila el .ipa y lo sube a TestFlight"
  lane :beta do
    # La API Key de App Store Connect llega por env vars (issuer id, key id, key p8).
    #
    # ⚠️ ERROR "Authentication credentials are missing or invalid" en el upload:
    # casi siempre es un MISMATCH de formato del .p8 en el secret ASC_KEY_CONTENT — el
    # gemelo iOS del "Invalid JWT Signature" de Android (pegar crudo en vez de base64).
    # Antes forzábamos is_key_content_base64: true; si el secret venía como .p8 CRUDO
    # (PEM con "-----BEGIN PRIVATE KEY-----"), fastlane lo base64-decodificaba → clave
    # basura → token JWT inválido → Apple rechaza. Ahora AUTO-DETECTAMOS: si el contenido
    # trae el header PEM es crudo (is_key_content_base64=false); si no, es base64. Así el
    # upload funciona sin importar en qué formato esté guardado el secret. key_id/issuer
    # con .strip por si el secret arrastra un salto de línea.
    asc_key = ENV["ASC_KEY_CONTENT"].to_s
    asc_key_is_b64 = !asc_key.include?("PRIVATE KEY")
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"].to_s.strip,
      issuer_id: ENV["ASC_ISSUER_ID"].to_s.strip,
      key_content: asc_key,
      is_key_content_base64: asc_key_is_b64,
    )

    # Build number único = (último de TestFlight) + 1, para no chocar en cada corrida.
    # El versionName (CFBundleShortVersionString) queda como esté en el Info.plist.
    ultimo = latest_testflight_build_number(
      app_identifier: "pe.saniape.app",
      initial_build_number: 6,   # ya subimos hasta el 6 a mano
    ) rescue 6
    set_info_plist_value(path: "iosApp/iosApp/Info.plist", key: "CFBundleVersion", value: (ultimo + 1).to_s)

    # Compila el framework Kotlin + el app iOS y produce el .ipa firmado.
    # La firma la resuelve Xcode con el perfil/cert que instala el workflow (o match).
    #
    # destination fuerza DISPOSITIVO real (cualquier iPhone). Sin esto, con Xcode 16.2 gym
    # intentaba archivar para el SIMULADOR y fallaba ("No simulator runtime version").
    # OJO: NO pasar `sdk:` junto a un destination genérico — xcodebuild no puede casar
    # `-sdk iphoneos` con `-destination generic/platform=iOS` y declara el destino
    # "ineligible". El destination genérico solo YA significa dispositivo; el sdk sobra.
    # Xcode 16.2 necesita el destino explícito (dispositivo). Sin clean, para reusar el
    # caché de DerivedData entre corridas (es lo que hace el build rápido).
    build_app(
      project: "iosApp/iosApp.xcodeproj",
      scheme: "iosApp",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ios",
      destination: "generic/platform=iOS",
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,  # no bloquea el runner esperando el procesado de Apple
    )
  end
end
