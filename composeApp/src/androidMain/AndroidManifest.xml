<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Ubicación para el mapa de clínicas cercanas -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- osmdroid: estado de red para cargar los tiles de OpenStreetMap -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Notificaciones en la barra (Android 13+ las pide en runtime) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".SaniaApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Sania"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Sania">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|mnc|colorMode|density|fontScale|fontWeightAdjustment|keyboard|layoutDirection|locale|mcc|navigation|smallestScreenSize|touchscreen|uiMode"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Sania">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Visor de HTML (historia clínica imprimible servida con Bearer) -->
        <activity
            android:name=".ui.VisorHtmlActivity"
            android:exported="false"
            android:label="Historia clínica" />

        <!-- FCM: recibe los push del dashboard y los muestra en la barra (SaniaFcmService).
             Solo actúa si FirebaseCfg tiene los valores del proyecto (init programática). -->
        <service
            android:name=".push.SaniaFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- FileProvider: URI temporal donde la cámara escribe la foto clínica (tomar foto).
             NO requiere permiso CAMERA: TakePicture delega en la app de cámara del sistema. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>